<?xml version="1.0" encoding="UTF-8"?>
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://community.rti.com/schema/7.0.0/rti_dds_profiles.xsd" version="7.0.0">
    <types>
      <module name="TMS">
        <module name="Topics">
          <const name="TOPIC_HEARTBEAT" type="boolean" value="1"/>
        </module>
      </module>
    </types>

    <domain_library name="MyDomainLib">
    </domain_library>

    <domain_participant_library name="TMSParticipantLib">
      <domain_participant name="SmartDistributionSystem" domain_ref="MyDomainLib::MyDomain">
        <publisher name="SDS_Publisher">
          <data_writer name="HeartbeatWriter" topic_ref="Heartbeat">
            <datawriter_qos base_name="TMSQoSLib::Medium">
            </datawriter_qos>
          </data_writer>
          <data_writer name="DeviceInfoWriter" topic_ref="DeviceInfo">
            <datawriter_qos base_name="TMSQoSLib::PublishLast">
            </datawriter_qos>
          </data_writer>
          <data_writer name="ACMeasurementUpdateWriter" topic_ref="ACMeasurementUpdate">
            <datawriter_qos base_name="TMSQoSLib::Medium">
            </datawriter_qos>
          </data_writer>
          <data_writer name="PowerPortStateWriter" topic_ref="PowerPortState">
            <datawriter_qos base_name="TMSQoSLib::PublishLast">
            </datawriter_qos>
          </data_writer>
          <data_writer name="PowerSwitchRequestWriter" topic_ref="PowerSwitchRequest">
            <datawriter_qos base_name="TMSQoSLib::Command">
            </datawriter_qos>
          </data_writer>
          <data_writer name="ReplyWriter" topic_ref="Reply">
            <datawriter_qos base_name="TMSQoSLib::Reply">
            </datawriter_qos>
          </data_writer>
        </publisher>
        <subscriber name="SDS_Subscriber">
          <data_reader name="HeartbeatReader" topic_ref="Heartbeat">
            <datareader_qos base_name="TMSQoSLib::Medium">
            </datareader_qos>
          </data_reader>
          <data_reader name="DeviceInfoReader" topic_ref="DeviceInfo">
            <datareader_qos base_name="TMSQoSLib::PublishLast">
            </datareader_qos>
          </data_reader>
          <data_reader name="ACMeasurementUpdateReader" topic_ref="ACMeasurementUpdate">
            <datareader_qos base_name="TMSQoSLib::Medium">
            </datareader_qos>
          </data_reader>
          <data_reader name="PowerPortStateReader" topic_ref="PowerPortState">
            <datareader_qos base_name="TMSQoSLib::PublishLast">
            </datareader_qos>
          </data_reader>
          <data_reader name="PowerSwitchRequestReader" topic_ref="PowerSwitchRequest">
            <datareader_qos base_name="TMSQoSLib::Command">
            </datareader_qos>
          </data_reader>
          <data_reader name="ReplyReader" topic_ref="Reply">
            <datareader_qos base_name="TMSQoSLib::Reply">
            </datareader_qos>
          </data_reader>
        </subscriber>
        <domain_participant_qos base_name="TMSQoSLib::LargeTopicParticipantQoS">
        </domain_participant_qos>
      </domain_participant>
    </domain_participant_library>

</dds>
